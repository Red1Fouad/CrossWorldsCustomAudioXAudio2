{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Mod DLL",
            "type": "shell",
            "command": "cl.exe",
            "args": [
                "/EHsc",           // Enable C++ exceptions
                "/LD",             // Create a DLL
                "/std:c++17",      // Use C++17 standard
                "/MD",             // Use Multi-threaded DLL Runtime (matches MinHook-md)
                "/O2",             // Optimize for speed
                "dllmain.cpp",     // Input file (includes others)
                "/Fe:main.dll"     // Output filename
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        }
    ]
}
